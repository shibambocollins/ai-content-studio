# ---- Server ----
# 5000/5050 are commonly reserved by Windows (Hyper-V) or already in use.
# 8787 is a safe default that's rarely blocked.
PORT=8787
NODE_ENV=development

# ---- Database ----
# Postgres connection string. Free options: Supabase, Neon, or Render Postgres.
# Supabase example: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=

# Comma-separated list of origins allowed to call this API.
# Local dev example: http://localhost:5173
# Add your deployed Vercel URL here once you have it, e.g.
# CORS_ORIGIN=http://localhost:5173,https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# Secret used to sign JWTs. Generate a strong random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# ---- Provider fallback chain ----
# Order in which providers are tried for TEXT generation. First one that
# succeeds wins; if it errors or is unconfigured, the next one is tried.
# Valid names: gemini, groq, openrouter
PROVIDER_CHAIN=gemini,groq,openrouter

# ---- Gemini (https://aistudio.google.com/apikey) ----
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ---- Groq (https://console.groq.com) — free, fast, OpenAI-compatible ----
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

# ---- OpenRouter (https://openrouter.ai/keys) — free-tier models available,
# also OpenAI-compatible. Pick any ":free" model slug from openrouter.ai/models
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ---- Image generation fallback chain ----
# Gemini's Nano Banana model needs billing enabled on the Cloud project to
# get any real quota. Cloudflare Workers AI is a genuinely free fallback
# (Stable Diffusion/Flux models, no billing required).
IMAGE_PROVIDER_CHAIN=gemini,cloudflare

# ---- Cloudflare Workers AI (https://dash.cloudflare.com) — free image gen ----
# Account ID: dashboard Overview page, right sidebar (or the Workers & Pages page).
# API Token: My Profile > API Tokens > Create Token > "Workers AI" template.
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell
